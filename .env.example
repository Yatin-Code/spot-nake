# ── Spot-Nake Configuration (safe to commit — no secrets) ──

# 1. Telegram
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
TELEGRAM_OWNER_ID="your-telegram-user-id"

# 2. Google AI Studio (Primary — Intent Parsing)
GEMINI_API_KEY="your-google-ai-studio-key"

# 3. OpenRouter (Fallback — Conversation)
OPENROUTER_API_KEY="your-openrouter-key"

# 4. Together.ai (Backup — Evaluation & Ranking)
TOGETHER_API_KEY="your-together-ai-key"

# 5. Nvidia NIM (Embeddings — Semantic Mapping)
NVIDIA_API_KEY="your-nvidia-nim-key"

# 6. MongoDB Atlas
MONGODB_URI="mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/spotnake"

# 7. YouTube Music OAuth
YOUTUBE_CLIENT_ID="your-oauth-client-id"
YOUTUBE_CLIENT_SECRET="your-oauth-client-secret"

# 8. App Settings
PORT=7860
DOWNLOAD_DIR="/data/downloads"
DB_NAME="spotnake"
MAX_RECOMMENDATIONS=10
AUDIO_FORMAT="mp3"
AUDIO_QUALITY="320"
LOG_LEVEL="INFO"
